# =============================================================================
# Environment variables — copy to the paths below before running locally
#
#   backend/.env   → Backend section
#   frontend/.env  → Frontend section
#
# Never commit real secrets. Use placeholder values only in this file.
# =============================================================================

# --- Backend (backend/.env) ---

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/discord_bot

# JWT signing secret (use a long random string in production)
JWT_SECRET=your-jwt-secret-change-me

# Discord application credentials (Discord Developer Portal)
DISCORD_APP_ID=your-discord-application-id
DISCORD_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key-hex

# Slack incoming webhook for mirroring command activity (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Groq API key for AI analysis of /report submissions
GROQ_API_KEY=your-groq-api-key

# --- Frontend (frontend/.env) ---

# Backend API base URL (must match where the Express server is running)
VITE_API_URL=http://localhost:3001/api
